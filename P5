#include <stdio.h>
#include <string.h>

int main() {
    char str[100];
    int len;

    printf("Enter a binary string: ");
    scanf("%s", str);

    len = strlen(str);

    // Check if string length is at least 2
    if (len >= 2 && str[len - 2] == '0' && str[len - 1] == '1') {
        printf("String Accepted (Ends with 01)\n");
    } else {
        printf("String Rejected\n");
    }

    return 0;
}
